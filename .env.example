# Open-Meteo API 配置
#
# 使用方法:
# 1. 复制此文件为 .env
# 2. 填写你的配置信息
# 3. 不要提交 .env 到 git

# Open-Meteo 位置配置
# 纬度 (例如：广州=23.1291, 北京=39.9042, 上海=31.2304, 深圳=22.5431)
OPENMETEO_LATITUDE=23.1291

# 经度
OPENMETEO_LONGITUDE=113.2644

# 位置名称（用于显示）
OPENMETEO_LOCATION_NAME=广州

# 说明:
# - Open-Meteo 是免费天气 API，无需认证
# - 文档：https://open-meteo.com/en/docs
